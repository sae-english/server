# Пример файла с секретами для prod.
# На сервере: скопируй в .env и подставь свои значения.
#   cp .env.example .env && chmod 600 .env
# В git коммитить только этот файл; .env — никогда.

# БД
SPRING_DATASOURCE_PASSWORD=

# Telegram (рассылка слов в личку)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Yandex Translate (кнопка «Перевести» в UI)
YANDEX_TRANSLATE_API_KEY=
YANDEX_TRANSLATE_FOLDER_ID=
